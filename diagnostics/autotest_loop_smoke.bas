10 PRINT "AUTOTEST LOOP: SUPPLY SIM"
20 FAILS=0
30 DIM INV(3)
40 INV(1)=10
50 INV(2)=5
60 INV(3)=0
70 FOR DAY=1 TO 3
80 INV(1)=INV(1)-2
90 INV(2)=INV(2)+DAY
100 IF INV(1)<0 THEN FAILS=FAILS+1
110 NEXT DAY
120 PRINT "FOOD=";INV(1)
130 PRINT "TOOLS=";INV(2)
140 IF INV(1)=4 AND INV(2)=11 THEN
150 PRINT "PASS SIM TOTALS"
160 ELSE
170 PRINT "FAIL SIM TOTALS"
180 FAILS=FAILS+1
190 ENDIF
200 S$="DAYS=3"
210 N=VAL(RIGHT$(S$,1))
220 PRINT "N=";N
230 IF N=3 AND LEN(S$)=6 THEN
231 PRINT "PASS STRING VAL"
232 ELSE
233 PRINT "FAIL STRING VAL"
234 FAILS=FAILS+1
235 ENDIF
240 DIM DICE(5)
250 DIM HOLD(5)
260 FOR I=1 TO 5
270 DICE(I)=I
280 HOLD(I)=0
290 NEXT I
300 H$="25"
310 FOR I=1 TO LEN(H$)
320 CH$=MID$(H$,I,1)
330 POS=VAL(CH$)
340 IF POS>=1 AND POS<=5 THEN HOLD(POS)=1
350 NEXT I
360 FOR I=1 TO 5
370 IF HOLD(I)=0 THEN DICE(I)=DICE(I)+10
380 NEXT I
390 PRINT "DICE=";DICE(1);DICE(2);DICE(3);DICE(4);DICE(5)
400 IF DICE(2)=2 AND DICE(5)=5 AND DICE(1)=11 AND DICE(3)=13 AND DICE(4)=14 THEN
410 PRINT "PASS HOLD SIM"
420 ELSE
430 PRINT "FAIL HOLD SIM"
440 FAILS=FAILS+1
450 ENDIF
460 PRINT "FAILS=";FAILS
470 IF FAILS=0 THEN PRINT "AUTOTEST PASS" ELSE PRINT "AUTOTEST FAIL"
480 END
