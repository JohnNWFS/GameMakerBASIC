10 REM ============================================================
20 REM NW-BASIC PROGRAM RUNTIME TEST — Phase 10a
30 REM Targets: sorted execution order, O(1) GOTO/GOSUB, inline GOTO
40 REM          GOSUB/RETURN, out-of-order line numbers in editor
50 REM Output:  TEST: name = PASS  or  TEST: name = FAIL
60 REM Paste into editor (lines intentionally out of numeric order), RUN
70 REM ============================================================
80 CLS
90 PRINT "NW-BASIC PROGRAM RUNTIME TEST (Phase 10a)"
100 PRINT "=========================================="
110 PRINT ""
120 REM
200 REM --- SECTION 1: sorted run order (115 before 9500) ---
210 PRINT "SECTION 1: Sorted execution"
220 REM
9500 HIGH = 1
115 LOW = 1
125 IF LOW = 1 AND HIGH = 0 THEN PRINT "TEST: SORT_ORDER = PASS" ELSE PRINT "TEST: SORT_ORDER = FAIL"
135 PRINT ""
140 REM
300 REM --- SECTION 2: GOTO ---
310 PRINT "SECTION 2: GOTO"
320 GOTO 700
330 PRINT "TEST: GOTO_SKIP = FAIL"
700 PRINT "TEST: GOTO_700 = PASS"
710 PRINT ""
720 REM
800 REM --- SECTION 3: GOSUB / RETURN ---
810 PRINT "SECTION 3: GOSUB"
820 GOSUB 8000
830 IF SUBOK = 1 THEN PRINT "TEST: GOSUB_RET = PASS" ELSE PRINT "TEST: GOSUB_RET = FAIL"
840 PRINT ""
850 REM
900 REM --- SECTION 4: inline IF with GOTO ---
910 PRINT "SECTION 4: Inline GOTO"
920 FLAG = 0
930 IF 1 = 1 THEN GOTO 960 ELSE FLAG = 9
940 PRINT "TEST: INLINE_GOTO = FAIL"
950 GOTO 980
960 FLAG = 1
970 IF FLAG = 1 THEN PRINT "TEST: INLINE_GOTO = PASS" ELSE PRINT "TEST: INLINE_GOTO = FAIL"
980 PRINT ""
990 REM
1000 REM --- SECTION 5: nested GOSUB ---
1010 PRINT "SECTION 5: Nested GOSUB"
1020 DEPTH = 0
1030 GOSUB 9100
1040 IF DEPTH = 2 THEN PRINT "TEST: NEST_GOSUB = PASS" ELSE PRINT "TEST: NEST_GOSUB = FAIL ("; DEPTH; ")"
1050 PRINT ""
1060 PRINT "PROGRAM RUNTIME TEST COMPLETE"
1070 END
8000 SUBOK = 1
8010 RETURN
9100 GOSUB 9200
9110 GOSUB 9200
9120 RETURN
9200 DEPTH = DEPTH + 1
9210 RETURN