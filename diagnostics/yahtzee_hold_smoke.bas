10 PRINT "YAHTZEE HOLD / ARRAY SMOKE"
20 PRINT "TEST A: DIRECT HOLD FLAGS"
30 DIM DICE(5)
40 DIM HOLD(5)
50 FOR I = 1 TO 5
60 DICE(I) = I
70 HOLD(I) = 0
80 NEXT I
90 HOLD(2) = 1
100 HOLD(4) = 1
110 PRINT "START DICE:";DICE(1);DICE(2);DICE(3);DICE(4);DICE(5)
120 PRINT "HOLD FLAGS:";HOLD(1);HOLD(2);HOLD(3);HOLD(4);HOLD(5)
130 FOR I = 1 TO 5
140 IF HOLD(I) = 0 THEN DICE(I) = 10 + I
150 NEXT I
160 PRINT "AFTER REROLL:";DICE(1);DICE(2);DICE(3);DICE(4);DICE(5)
170 IF DICE(2) = 2 AND DICE(4) = 4 THEN PRINT "PASS A HELD DICE STAY" ELSE PRINT "FAIL A HELD DICE CHANGED"
180 IF DICE(1) = 11 AND DICE(3) = 13 AND DICE(5) = 15 THEN PRINT "PASS A FREE DICE CHANGE" ELSE PRINT "FAIL A FREE DICE WRONG"
190 PRINT
200 PRINT "TEST B: YAHTZEE-LIKE INPUT PARSE"
210 FOR I = 1 TO 5
220 DICE(I) = I
230 HOLD(I) = 0
240 NEXT I
250 HOLD_INPUT$ = "24"
260 FOR I = 1 TO LEN(HOLD_INPUT$)
270 CH$ = MID$(HOLD_INPUT$, I, 1)
280 POS = 0
290 IF CH$ = "1" THEN POS = 1
300 IF CH$ = "2" THEN POS = 2
310 IF CH$ = "3" THEN POS = 3
320 IF CH$ = "4" THEN POS = 4
330 IF CH$ = "5" THEN POS = 5
340 IF POS >= 1 AND POS <= 5 THEN HOLD(POS) = 1
350 NEXT I
360 PRINT "PARSED HOLDS:";HOLD(1);HOLD(2);HOLD(3);HOLD(4);HOLD(5)
370 FOR I = 1 TO 5
380 IF HOLD(I) = 0 THEN DICE(I) = 20 + I
390 NEXT I
400 PRINT "AFTER REROLL:";DICE(1);DICE(2);DICE(3);DICE(4);DICE(5)
410 IF DICE(2) = 2 AND DICE(4) = 4 THEN PRINT "PASS B PARSED HOLDS STAY" ELSE PRINT "FAIL B PARSED HOLDS CHANGED"
420 PRINT
430 PRINT "TEST C: YAHTZEE TOGGLE LINE"
440 FOR I = 1 TO 5
450 DICE(I) = I
460 HOLD(I) = 0
470 NEXT I
480 POS = 3
490 IF HOLD(POS) = 0 THEN HOLD(POS) = 1 ELSE HOLD(POS) = 0
500 POS = 5
510 IF HOLD(POS) = 0 THEN HOLD(POS) = 1 ELSE HOLD(POS) = 0
520 PRINT "TOGGLE HOLDS:";HOLD(1);HOLD(2);HOLD(3);HOLD(4);HOLD(5)
530 FOR I = 1 TO 5
540 IF HOLD(I) = 0 THEN DICE(I) = 30 + I
550 NEXT I
560 PRINT "AFTER REROLL:";DICE(1);DICE(2);DICE(3);DICE(4);DICE(5)
570 IF DICE(3) = 3 AND DICE(5) = 5 THEN PRINT "PASS C TOGGLED HOLDS STAY" ELSE PRINT "FAIL C TOGGLED HOLDS CHANGED"
580 PRINT
590 PRINT "TEST D: ORIGINAL BLOCK-IF SHAPE"
600 FOR I = 1 TO 5
610 HOLD(I) = 0
620 NEXT I
630 POS = 2
640 IF POS < 1 OR POS > 5 THEN
650 IF HOLD(POS) = 0 THEN HOLD(POS) = 1 ELSE HOLD(POS) = 0
660 ENDIF
670 PRINT "FALSE BLOCK HOLDS:";HOLD(1);HOLD(2);HOLD(3);HOLD(4);HOLD(5)
680 IF HOLD(1) = 0 AND HOLD(2) = 0 AND HOLD(3) = 0 AND HOLD(4) = 0 AND HOLD(5) = 0 THEN PRINT "PASS D BLOCK SKIP" ELSE PRINT "FAIL D BLOCK FELL THROUGH"
690 END
