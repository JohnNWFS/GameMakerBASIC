5 REM ============================================================
10 REM CRYSTAL CAVES — MODE 2,32 adventure POC (PLAYABLE)
20 REM Custom tiles + MAPNEW world + VIEW + MAPDRAW camera scroll
30 REM WASD move | key (*) in cave | gate (+) | gem (+) win | Q quit
40 REM ============================================================
50 MODE 2, 32
60 CLSCHAR 32, WHITE, BLACK
70 PRINTAT 0, 0, "BUILDING WORLD...", YELLOW, BLACK
80 GOSUB 9000
90 GOSUB 8000
100 VIEW 0, 2, 38, 18
110 PX = 4
120 PY = 4
130 CAMX = 0
140 CAMY = 0
150 HASKEY = 0
160 WON = 0
170 MOVES = 0
180 QUIT = 0
190 FOR I = 1 TO 16
200 K$ = INKEY$ + ""
210 NEXT I
220 GOSUB 6000
230 PRINTAT 0, 1, "WASD move   Q quit   find * in cave", YELLOW, BLACK
240 WHILE QUIT = 0 AND WON = 0
250 GOSUB 7000
260 WEND
270 IF WON = 1 THEN PRINTAT 12, 10, "YOU WIN!", LIME, BLACK
280 PRINTAT 0, 1, "DONE — press any key", CYAN, BLACK
290 K$ = INKEY$
300 PRINT ""
310 PRINT "ADVENTURE DONE  MOVES="; MOVES
320 END

6000 REM -------- RENDER --------
6010 GOSUB 6120
6020 DC = 1 - CAMX
6030 DR = 2 - CAMY
6040 MAPDRAW DC, DR
6050 SCX = PX - CAMX
6060 SCY = PY - CAMY + 2
6070 TILE SCX, SCY, 200, LIME, BLACK
6080 PRINTAT 0, 0, "MOVES "; MOVES; "   ", WHITE, BLACK
6090 IF HASKEY = 1 THEN PRINTAT 10, 0, "KEY YES", YELLOW, BLACK ELSE PRINTAT 10, 0, "KEY NO ", GRAY, BLACK
6100 IF WON = 0 THEN PRINTAT 22, 0, "FIND *", CYAN, BLACK
6110 RETURN

6120 REM -------- CAMERA --------
6130 CAMX = PX - 19
6140 IF CAMX < 0 THEN CAMX = 0
6150 IF CAMX > 2 THEN CAMX = 2
6160 CAMY = PY - 8
6170 IF CAMY < 0 THEN CAMY = 0
6180 IF CAMY > 8 THEN CAMY = 8
6190 RETURN

7000 REM -------- INPUT (modal INKEY$ — waits for your key) --------
7010 K$ = INKEY$
7020 IF K$ = "Q" OR K$ = "q" THEN QUIT = 1
7030 IF K$ = "Q" OR K$ = "q" THEN RETURN
7040 NX = PX
7050 NY = PY
7060 IF K$ = "W" OR K$ = "w" THEN NY = NY - 1
7070 IF K$ = "S" OR K$ = "s" THEN NY = NY + 1
7080 IF K$ = "A" OR K$ = "a" THEN NX = NX - 1
7090 IF K$ = "D" OR K$ = "d" THEN NX = NX + 1
7100 IF NX = PX AND NY = PY THEN RETURN
7110 GOSUB 7200
7120 RETURN

7200 REM -------- TRY MOVE --------
7210 GOSUB 6120
7220 DC = 1 - CAMX
7230 DR = 2 - CAMY
7240 MAPDRAW DC, DR
7250 TCX = NX - CAMX
7260 TCY = NY - CAMY + 2
7270 CH = TILECHAR(TCX, TCY)
7280 IF CH = 35 THEN RETURN
7290 IF CH = 201 THEN RETURN
7300 IF CH = 68 AND HASKEY = 0 THEN PRINTAT 0, 20, "GATE LOCKED — find * cave", RED, BLACK
7310 IF CH = 68 AND HASKEY = 0 THEN RETURN
7320 IF CH = 68 AND HASKEY = 1 THEN MAPSET NX, NY, 46, WHITE, BLACK
7330 IF CH = 42 THEN HASKEY = 1
7340 IF CH = 42 THEN MAPSET NX, NY, 46, WHITE, BLACK
7350 IF CH = 43 THEN WON = 1
7360 PX = NX
7370 PY = NY
7380 MOVES = MOVES + 1
7390 GOSUB 6000
7400 RETURN

8000 REM -------- BUILD WORLD (no bulk fill — MAPNEW sets floor) --------
8010 MAPNEW 40, 26, "island", 46, WHITE, BLACK
8020 FOR X = 0 TO 39
8030 MAPSET X, 0, 35, CYAN, BLACK
8040 MAPSET X, 25, 35, CYAN, BLACK
8050 NEXT X
8060 FOR Y = 0 TO 25
8070 MAPSET 0, Y, 35, CYAN, BLACK
8080 MAPSET 39, Y, 35, CYAN, BLACK
8090 NEXT Y
8100 MAPSET 8, 6, 201, GREEN, BLACK
8110 MAPSET 12, 8, 201, GREEN, BLACK
8120 MAPSET 15, 5, 201, GREEN, BLACK
8130 MAPSET 10, 12, 201, GREEN, BLACK
8140 MAPSET 6, 14, 201, GREEN, BLACK
8150 MAPSET 18, 10, 201, GREEN, BLACK
8160 MAPSET 30, 14, 201, GREEN, BLACK
8170 FOR X = 28 TO 37
8180 MAPSET X, 4, 35, GRAY, BLACK
8190 MAPSET X, 18, 35, GRAY, BLACK
8200 NEXT X
8210 FOR Y = 4 TO 18
8220 MAPSET 28, Y, 35, GRAY, BLACK
8230 MAPSET 37, Y, 35, GRAY, BLACK
8240 NEXT Y
8250 FOR X = 29 TO 36
8260 FOR Y = 5 TO 17
8270 MAPSET X, Y, 46, GRAY, BLACK
8280 NEXT Y
8290 NEXT X
8300 MAPSET 33, 10, 202, YELLOW, BLACK
8310 MAPSET 34, 11, 42, YELLOW, BLACK
8320 MAPSET 22, 12, 68, RED, BLACK
8330 MAPSET 24, 8, 43, YELLOW, BLACK
8340 RETURN

9000 REM -------- CUSTOM TILES 32x32 (compact) --------
9010 TILEDEF 200, 32, 32
9020 FOR I = 12 TO 19
9030 TILEPX 200, I, 12, 1
9040 TILEPX 200, I, 20, 1
9050 NEXT I
9060 FOR I = 8 TO 23
9070 TILEPX 200, 15, I, 1
9080 TILEPX 200, 16, I, 1
9090 NEXT I
9100 TILEDEF 201, 32, 32
9110 FOR Y = 8 TO 22
9120 FOR X = 12 TO 18
9130 IF ABS(X - 15) + ABS(Y - 15) < 7 THEN TILEPX 201, X, Y, 1
9140 NEXT X
9150 NEXT Y
9160 FOR I = 10 TO 21
9170 TILEPX 201, I, 24, 1
9180 NEXT I
9190 TILEDEF 202, 32, 32
9200 FOR X = 9 TO 22
9210 TILEPX 202, X, 19, 1
9220 NEXT X
9230 FOR Y = 14 TO 19
9240 TILEPX 202, 9, Y, 1
9250 TILEPX 202, 22, Y, 1
9260 NEXT Y
9270 RETURN