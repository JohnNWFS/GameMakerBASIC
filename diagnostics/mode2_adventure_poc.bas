5 REM ============================================================
10 REM CRYSTAL CAVES — MODE 2,32 adventure POC
20 REM Custom tiles + MAPNEW world + VIEW + MAPDRAW camera scroll
30 REM WASD move | key (*) in cave | gate (+) | gem (+) win | Q quit
40 REM ============================================================
50 MODE 2, 32
60 CLSCHAR 32, WHITE, BLACK
70 GOSUB 9000
80 GOSUB 8000
90 VIEW 0, 2, 38, 18
100 PX = 4
110 PY = 4
120 CAMX = 0
130 CAMY = 0
140 HASKEY = 0
150 WON = 0
160 MOVES = 0
170 QUIT = 0
180 GOSUB 6000
190 PRINTAT 0, 21, "CRYSTAL CAVES — WASD explore, Q quit", YELLOW, BLACK
200 WHILE QUIT = 0 AND WON = 0
210 GOSUB 7000
220 WEND
230 IF WON = 1 THEN PRINTAT 10, 10, "YOU WIN!", LIME, BLACK
240 PRINT ""
250 PRINT "ADVENTURE DONE  MOVES=" + STR$(MOVES)
260 END

6000 REM -------- RENDER --------
6010 GOSUB 6120
6020 DC = 1 - CAMX
6030 DR = 2 - CAMY
6040 MAPDRAW DC, DR
6050 SCX = PX - CAMX
6060 SCY = PY - CAMY + 2
6070 TILE SCX, SCY, 200, LIME, BLACK
6080 PRINTAT 0, 0, "MOVES " + STR$(MOVES) + "  ", WHITE, BLACK
6090 IF HASKEY = 1 THEN PRINTAT 10, 0, "KEY YES", YELLOW, BLACK ELSE PRINTAT 10, 0, "KEY NO ", GRAY, BLACK
6100 IF WON = 0 THEN PRINTAT 20, 0, "GET * KEY ", CYAN, BLACK
6110 RETURN

6120 REM -------- CAMERA --------
6130 CAMX = PX - 19
6140 IF CAMX < 0 THEN CAMX = 0
6150 IF CAMX > 2 THEN CAMX = 2
6160 CAMY = PY - 8
6170 IF CAMY < 0 THEN CAMY = 0
6180 IF CAMY > 8 THEN CAMY = 8
6190 RETURN

7000 REM -------- INPUT --------
7010 K$ = INKEY$ + ""
7020 IF K$ = "" THEN RETURN
7030 NX = PX
7040 NY = PY
7050 IF K$ = "W" OR K$ = "w" THEN NY = NY - 1
7060 IF K$ = "S" OR K$ = "s" THEN NY = NY + 1
7070 IF K$ = "A" OR K$ = "a" THEN NX = NX - 1
7080 IF K$ = "D" OR K$ = "d" THEN NX = NX + 1
7090 IF K$ = "Q" OR K$ = "q" THEN QUIT = 1
7100 IF K$ = "Q" OR K$ = "q" THEN RETURN
7110 IF NX = PX AND NY = PY THEN RETURN
7120 GOSUB 7200
7130 RETURN

7200 REM -------- TRY MOVE --------
7210 GOSUB 6120
7220 DC = 1 - CAMX
7230 DR = 2 - CAMY
7240 MAPDRAW DC, DR
7250 TCX = NX - CAMX
7260 TCY = NY - CAMY + 2
7270 CH = TILECHAR(TCX, TCY)
7280 IF CH = 35 THEN RETURN
7290 IF CH = 201 THEN RETURN
7300 IF CH = 68 AND HASKEY = 0 THEN PRINTAT 0, 20, "GATE LOCKED — find * cave", RED, BLACK
7310 IF CH = 68 AND HASKEY = 0 THEN RETURN
7320 IF CH = 68 AND HASKEY = 1 THEN MAPSET NX, NY, 46, WHITE, BLACK
7330 IF CH = 42 THEN HASKEY = 1
7340 IF CH = 42 THEN MAPSET NX, NY, 46, WHITE, BLACK
7350 IF CH = 43 THEN WON = 1
7360 PX = NX
7370 PY = NY
7380 MOVES = MOVES + 1
7390 GOSUB 6000
7400 RETURN

8000 REM -------- BUILD WORLD --------
8010 MAPNEW 40, 26, "island"
8020 FOR X = 0 TO 39
8030 FOR Y = 0 TO 25
8040 MAPSET X, Y, 46, WHITE, BLACK
8050 NEXT Y
8060 NEXT X
8070 FOR X = 0 TO 39
8080 MAPSET X, 0, 35, CYAN, BLACK
8090 MAPSET X, 25, 35, CYAN, BLACK
8100 NEXT X
8110 FOR Y = 0 TO 25
8120 MAPSET 0, Y, 35, CYAN, BLACK
8130 MAPSET 39, Y, 35, CYAN, BLACK
8140 NEXT Y
8150 MAPSET 8, 6, 201, GREEN, BLACK
8160 MAPSET 12, 8, 201, GREEN, BLACK
8170 MAPSET 15, 5, 201, GREEN, BLACK
8180 MAPSET 10, 12, 201, GREEN, BLACK
8190 MAPSET 6, 14, 201, GREEN, BLACK
8200 MAPSET 18, 10, 201, GREEN, BLACK
8210 MAPSET 30, 14, 201, GREEN, BLACK
8220 FOR X = 28 TO 37
8230 MAPSET X, 4, 35, GRAY, BLACK
8240 MAPSET X, 18, 35, GRAY, BLACK
8250 NEXT X
8260 FOR Y = 4 TO 18
8270 MAPSET 28, Y, 35, GRAY, BLACK
8280 MAPSET 37, Y, 35, GRAY, BLACK
8290 NEXT Y
8300 MAPSET 32, 4, 35, GRAY, BLACK
8310 MAPSET 33, 4, 35, GRAY, BLACK
8320 FOR X = 29 TO 36
8330 FOR Y = 5 TO 17
8340 MAPSET X, Y, 46, GRAY, BLACK
8350 NEXT Y
8360 NEXT X
8370 MAPSET 33, 10, 202, YELLOW, BLACK
8380 MAPSET 34, 11, 42, YELLOW, BLACK
8390 MAPSET 22, 12, 68, RED, BLACK
8400 MAPSET 24, 8, 43, YELLOW, BLACK
8410 RETURN

9000 REM -------- CUSTOM TILES 32x32 --------
9010 TILEDEF 200, 32, 32
9020 FOR I = 10 TO 21
9030 TILEPX 200, I, 26, 1
9040 NEXT I
9050 FOR I = 12 TO 19
9060 TILEPX 200, I, 10, 1
9070 TILEPX 200, I, 11, 1
9080 TILEPX 200, I, 12, 1
9090 NEXT I
9100 FOR I = 8 TO 12
9110 TILEPX 200, 14, I, 1
9120 TILEPX 200, 15, I, 1
9130 NEXT I
9140 TILEDEF 201, 32, 32
9150 FOR I = 4 TO 27
9160 TILEPX 201, I, 24, 1
9170 TILEPX 201, I, 25, 1
9180 NEXT I
9190 FOR Y = 6 TO 22
9200 FOR X = 10 TO 21
9210 IF ABS(X - 15) + ABS(Y - 14) < 10 THEN TILEPX 201, X, Y, 1
9220 NEXT X
9230 NEXT Y
9240 TILEDEF 202, 32, 32
9250 FOR X = 8 TO 23
9260 TILEPX 202, X, 18, 1
9270 TILEPX 202, X, 19, 1
9280 TILEPX 202, X, 20, 1
9290 NEXT X
9300 FOR Y = 14 TO 20
9310 TILEPX 202, 8, Y, 1
9320 TILEPX 202, 23, Y, 1
9330 NEXT Y
9340 RETURN