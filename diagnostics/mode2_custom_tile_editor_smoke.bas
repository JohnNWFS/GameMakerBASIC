5 REM AUTOTEST_SCREENSHOT
10 MODE 2,16
20 CLSCHAR 32, WHITE, BLACK
30 PRINTAT 1,1,"MODE 2 CUSTOM TILE SMOKE", YELLOW, BLACK
40 TILEDEF 200,16,16
50 FOR I=0 TO 15
60 TILEPX 200,I,I,1
70 TILEPX 200,15-I,I,1
80 NEXT I
90 TILE 2,4,200,CYAN,BLACK
100 DRAWSTR 4,4,"STANDARD TEXT STILL WORKS", WHITE, BLACK
110 IF TILEBIT(200,0,0)=1 THEN
120 PRINTAT 1,7,"PASS BIT BEFORE SAVE", GREEN, BLACK
130 ELSE
140 PRINTAT 1,7,"FAIL BIT BEFORE SAVE", RED, BLACK
150 ENDIF
160 TILESAVE "codex_custom_tile"
170 TILECLEAR 200
180 IF TILEBIT(200,0,0)=0 THEN
190 PRINTAT 1,8,"PASS CLEAR", GREEN, BLACK
200 ELSE
210 PRINTAT 1,8,"FAIL CLEAR", RED, BLACK
220 ENDIF
230 TILELOAD "codex_custom_tile"
240 IF TILEBIT(200,0,0)=1 THEN
250 PRINTAT 1,9,"PASS LOAD BIT 0,0", GREEN, BLACK
260 ELSE
270 PRINTAT 1,9,"FAIL LOAD BIT 0,0", RED, BLACK
280 ENDIF
290 IF TILEBIT(200,8,7)=1 THEN
300 PRINTAT 1,10,"PASS LOAD BIT 8,7", GREEN, BLACK
310 ELSE
320 PRINTAT 1,10,"FAIL LOAD BIT 8,7", RED, BLACK
330 ENDIF
340 IF TILEBIT(200,1,0)=0 THEN
350 PRINTAT 1,11,"PASS LOAD OFF BIT", GREEN, BLACK
360 ELSE
370 PRINTAT 1,11,"FAIL LOAD OFF BIT", RED, BLACK
380 ENDIF
390 TILE 2,13,200,MAGENTA,BLACK
400 PRINTAT 4,13,"CUSTOM TILE RELOADED", WHITE, BLACK
410 PRINT "TRANSCRIPT CUSTOM TILE DONE"
420 END
