10 PRINT "AUTOTEST: BLOCK COMPOUND IF"
20 FAILS=0
30 A=1
40 B=1
50 C=1
60 D=1
70 E=1
80 IF A=1 AND B=1 AND C=1 AND D=1 AND E=1 THEN
90 PRINT "PASS TRUE BLOCK"
100 ELSE
110 PRINT "FAIL ELSE RAN"
120 FAILS=FAILS+1
130 ENDIF
