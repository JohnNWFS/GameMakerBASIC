10 REM ============================================================
20 REM NW-BASIC SPRITE TEST — struct slot modernization (Phase 3)
30 REM Targets: DEF/SHOW/MOVE/HIDE/CLEAR, FG/BG/SCALE/ANGLE,
40 REM          SPRITEX/Y/HIT, COLOR+ROW, variable coordinates
50 REM Output:  TEST: name = PASS  or  TEST: name = FAIL
60 REM Runs in text mode (MODE 0). Paste into editor, RUN.
70 REM Optional: REM AUTOTEST_SCREENSHOT for visual check
80 REM (Same coverage as stress_sprite_struct.bas)
90 REM ============================================================
100 CLS
110 PRINT "NW-BASIC SPRITE TEST (Phase 3)"
120 PRINT "==============================="
130 PRINT ""
140 REM
150 REM Minimal 16x16 mono car shape (64 hex nibbles, MSB first)
160 CAR$ = "000000003CC37FF7FFFFFFFFFFFFFFFFFFFFFFFFFFFF7FF73CC3000000000000"
170 DOT$ = "8000000000000000800000000000000080000000000000080000000000000000"
180 REM
200 REM --- SECTION 1: MONO DEF + FG/BG ---
210 PRINT "SECTION 1: Mono define"
220 SPRITE DEF 1, CAR$
230 SPRITE FG 1, 6
240 SPRITE BG 1, 0
250 SPRITE SHOW 1, 50, 60
260 IF SPRITEX(1) = 50 THEN PRINT "TEST: DEF_OK = PASS" ELSE PRINT "TEST: DEF_OK = FAIL ("; SPRITEX(1); ")"
270 SPRITE HIDE 1
280 PRINT ""
290 REM
300 REM --- SECTION 2: SHOW / MOVE / SPRITEX/Y ---
310 PRINT "SECTION 2: Show and move"
320 X = 320
330 Y = 240
340 SPRITE SHOW 1, X, Y, 0
350 IF SPRITEX(1) = 320 THEN PRINT "TEST: SHOW_X = PASS" ELSE PRINT "TEST: SHOW_X = FAIL ("; SPRITEX(1); ")"
360 IF SPRITEY(1) = 240 THEN PRINT "TEST: SHOW_Y = PASS" ELSE PRINT "TEST: SHOW_Y = FAIL ("; SPRITEY(1); ")"
370 X = 400 : Y = 300
380 SPRITE MOVE 1, X, Y
390 IF SPRITEX(1) = 400 THEN PRINT "TEST: MOVE_X = PASS" ELSE PRINT "TEST: MOVE_X = FAIL ("; SPRITEX(1); ")"
400 IF SPRITEY(1) = 300 THEN PRINT "TEST: MOVE_Y = PASS" ELSE PRINT "TEST: MOVE_Y = FAIL ("; SPRITEY(1); ")"
410 PRINT ""
420 REM
500 REM --- SECTION 3: ANGLE + SCALE (state retained after MOVE) ---
510 PRINT "SECTION 3: Angle and scale"
520 SPRITE ANGLE 1, 45
530 SPRITE SCALE 1, 4
540 IF SPRITEX(1) = 400 THEN PRINT "TEST: ANGLE_KEEP_POS = PASS" ELSE PRINT "TEST: ANGLE_KEEP_POS = FAIL"
550 PRINT ""
560 REM
600 REM --- SECTION 4: SPRITEHIT overlap logic ---
610 PRINT "SECTION 4: Sprite hit"
620 SPRITE DEF 2, DOT$
630 SPRITE FG 2, 3
640 SPRITE SCALE 2, 4
650 SPRITE MOVE 1, 200, 200
660 SPRITE SHOW 2, 200, 200
670 IF SPRITEHIT(1, 2) = 1 THEN PRINT "TEST: HIT_OVERLAP = PASS" ELSE PRINT "TEST: HIT_OVERLAP = FAIL"
680 SPRITE MOVE 2, 900, 200
690 IF SPRITEHIT(1, 2) = 0 THEN PRINT "TEST: HIT_SEPARATE = PASS" ELSE PRINT "TEST: HIT_SEPARATE = FAIL"
700 SPRITE MOVE 2, 250, 200
710 IF SPRITEHIT(1, 2) = 1 THEN PRINT "TEST: HIT_NEAR = PASS" ELSE PRINT "TEST: HIT_NEAR = FAIL"
720 PRINT ""
730 REM
800 REM --- SECTION 5: HIDE ---
810 PRINT "SECTION 5: Hide"
820 SPRITE HIDE 2
830 IF SPRITEHIT(1, 2) = 0 THEN PRINT "TEST: HIDE_NO_HIT = PASS" ELSE PRINT "TEST: HIDE_NO_HIT = FAIL"
840 SPRITE SHOW 2, 250, 200
850 IF SPRITEHIT(1, 2) = 1 THEN PRINT "TEST: SHOW_AGAIN_HIT = PASS" ELSE PRINT "TEST: SHOW_AGAIN_HIT = FAIL"
860 PRINT ""
870 REM
900 REM --- SECTION 6: COLOUR MODE (SPRITE COLOR + ROW) ---
910 PRINT "SECTION 6: Colour rows"
920 SPRITE COLOR 3
930 SPRITE ROW 3, 1, "123456789ABCDEF0"
940 SPRITE ROW 3, 2, "FEDCBA9876543210"
950 SPRITE FG 3, 0
960 SPRITE SHOW 3, 100, 100
970 IF SPRITEX(3) = 100 THEN PRINT "TEST: COLOR_SHOW = PASS" ELSE PRINT "TEST: COLOR_SHOW = FAIL"
980 PRINT ""
990 REM
1000 REM --- SECTION 7: HIDE ALL + CLEAR ---
1010 PRINT "SECTION 7: Cleanup"
1020 SPRITE HIDE ALL
1030 IF SPRITEHIT(1, 2) = 0 THEN PRINT "TEST: HIDE_ALL = PASS" ELSE PRINT "TEST: HIDE_ALL = FAIL"
1040 SPRITE CLEAR
1050 IF SPRITEX(1) = 0 THEN PRINT "TEST: CLEAR_RESET = PASS" ELSE PRINT "TEST: CLEAR_RESET = FAIL ("; SPRITEX(1); ")"
1060 PRINT ""
1070 PRINT "SPRITE TEST COMPLETE"
1080 PRINT "If all lines show PASS, Phase 3 is good."
1090 END