5 REM AUTOTEST_SCREENSHOT
10 MODE 2,16
20 CLSCHAR 32, WHITE, BLACK
30 R=0
40 FAILS=0
50 PRINTAT 0,R,"NW-BASIC MODE 2 TILE INVENTORY", YELLOW, BLACK
60 R=R+1
70 PRINTAT 0,R,"AUTO CHECKS: TEXT, FLOW, DATA, ARRAYS, MODE 2", CYAN, BLACK
80 R=R+2
90 A=5
100 B=2
110 C=A*B+10/2-1
120 IF C=14 AND A>B THEN
130 PRINTAT 0,R,"PASS LET / IMPLICIT ASSIGN / MATH / AND", GREEN, BLACK
140 ELSE
150 PRINTAT 0,R,"FAIL LET / IMPLICIT ASSIGN / MATH / AND", RED, BLACK
160 FAILS=FAILS+1
170 ENDIF
180 R=R+1
190 S$="ABC"
200 T$=LEFT$(S$,1)+MID$(S$,2,1)+RIGHT$(S$,1)
210 IF T$="ABC" AND LEN(S$)=3 AND ASC("A")=65 AND VAL("42")=42 THEN
220 PRINTAT 0,R,"PASS STRING FUNCS LEFT MID RIGHT LEN ASC VAL", GREEN, BLACK
230 ELSE
240 PRINTAT 0,R,"FAIL STRING FUNCS LEFT MID RIGHT LEN ASC VAL", RED, BLACK
250 FAILS=FAILS+1
260 ENDIF
270 R=R+1
280 DIM ARR(3)
290 ARR(1)=4
300 ARR(2)=6
310 ARR(3)=ARR(1)+ARR(2)
320 IF ARR(3)=10 THEN
330 PRINTAT 0,R,"PASS DIM / ARRAY SET / ARRAY READ", GREEN, BLACK
340 ELSE
350 PRINTAT 0,R,"FAIL DIM / ARRAY SET / ARRAY READ", RED, BLACK
360 FAILS=FAILS+1
370 ENDIF
380 R=R+1
390 SUM=0
400 FOR I=1 TO 5
410 SUM=SUM+I
420 NEXT I
430 IF SUM=15 THEN
440 PRINTAT 0,R,"PASS FOR / NEXT", GREEN, BLACK
450 ELSE
460 PRINTAT 0,R,"FAIL FOR / NEXT", RED, BLACK
470 FAILS=FAILS+1
480 ENDIF
490 R=R+1
500 W=0
510 WHILE W<3
520 W=W+1
530 WEND
540 IF W=3 THEN
550 PRINTAT 0,R,"PASS WHILE / WEND", GREEN, BLACK
560 ELSE
570 PRINTAT 0,R,"FAIL WHILE / WEND", RED, BLACK
580 FAILS=FAILS+1
590 ENDIF
600 R=R+1
610 N=2
620 IF N=1 THEN
630 PRINTAT 0,R,"FAIL ELSEIF FALSE ARM", RED, BLACK
640 FAILS=FAILS+1
650 ELSEIF N=2 AND A=5 AND B=2 THEN
660 PRINTAT 0,R,"PASS BLOCK IF / ELSEIF / ELSE / ENDIF", GREEN, BLACK
670 ELSE
680 PRINTAT 0,R,"FAIL ELSEIF TRUE ARM", RED, BLACK
690 FAILS=FAILS+1
700 ENDIF
710 R=R+1
720 INLINE=0
730 IF N=2 THEN INLINE=1 ELSE INLINE=9
740 IF INLINE=1 THEN
750 PRINTAT 0,R,"PASS INLINE IF THEN ELSE", GREEN, BLACK
760 ELSE
770 PRINTAT 0,R,"FAIL INLINE IF THEN ELSE", RED, BLACK
780 FAILS=FAILS+1
790 ENDIF
800 R=R+1
810 GOTO 850
820 PRINTAT 0,R,"FAIL GOTO SKIP", RED, BLACK
830 FAILS=FAILS+1
840 R=R+1
850 PRINTAT 0,R,"PASS GOTO", GREEN, BLACK
860 R=R+1
870 SUBOK=0
880 GOSUB 9200
890 IF SUBOK=1 THEN
900 PRINTAT 0,R,"PASS GOSUB / RETURN", GREEN, BLACK
910 ELSE
920 PRINTAT 0,R,"FAIL GOSUB / RETURN", RED, BLACK
930 FAILS=FAILS+1
940 ENDIF
950 R=R+1
960 READ D1,D2$
970 RESTORE
980 READ D3
990 IF D1=7 AND D2$="OK" AND D3=7 THEN
1000 PRINTAT 0,R,"PASS DATA / READ / RESTORE", GREEN, BLACK
1010 ELSE
1020 PRINTAT 0,R,"FAIL DATA / READ / RESTORE", RED, BLACK
1030 FAILS=FAILS+1
1040 ENDIF
1050 R=R+1
1060 READ @NUMS,N1,N2
1070 RESTORE @NUMS
1080 READ @NUMS,N3
1090 IF N1=3 AND N2=4 AND N3=3 THEN
1100 PRINTAT 0,R,"PASS NAMED DATA STREAMS", GREEN, BLACK
1110 ELSE
1120 PRINTAT 0,R,"FAIL NAMED DATA STREAMS", RED, BLACK
1130 FAILS=FAILS+1
1140 ENDIF
1150 R=R+1
1160 COLOR GREEN
1170 BGCOLOR BLACK
1180 LOCATE R,0
1190 PRINT "PASS COLOR / BGCOLOR / LOCATE / PRINT"
1200 R=R+1
1210 PRINT "PASS PRINT SEMICOLON ";
1220 PRINT "CONTINUED"
1230 R=R+1
1240 PRINTAT 0,R,"PASS PRINTAT EXPLICIT COLORS", BLUE, YELLOW
1250 R=R+1
1260 CHARAT 0,R,65, MAGENTA, BLACK
1270 K=mode1_get_char(0,R)
1280 IF K=65 THEN
1290 PRINTAT 2,R,"PASS CHARAT / MODE1_GET_CHAR", GREEN, BLACK
1300 ELSE
1310 PRINTAT 2,R,"FAIL CHARAT / MODE1_GET_CHAR", RED, BLACK
1320 FAILS=FAILS+1
1330 ENDIF
1340 R=R+1
1350 PSET 0,R,66, CYAN, BLACK
1360 K=mode1_get_char(0,R)
1370 CN$=mode1_color_name(mode1_get_color(0,R))
1380 IF K=66 AND CN$="CYAN" THEN
1390 PRINTAT 2,R,"PASS PSET / MODE1_GET_COLOR / MODE1_COLOR_NAME", GREEN, BLACK
1400 ELSE
1410 PRINTAT 2,R,"FAIL PSET / MODE1_GET_COLOR / MODE1_COLOR_NAME", RED, BLACK
1420 FAILS=FAILS+1
1430 ENDIF
1440 R=R+1
1450 TILE 0,R,67, RED, BLACK
1460 PLOT 1,R,68, GREEN, BLACK
1470 TC=TILECHAR(0,R)
1480 TN$=TILENAME$(TILECOLOR(1,R))
1490 IF TC=67 AND TN$="GREEN" THEN
1500 PRINTAT 2,R,"PASS TILE/PLOT/TILECHAR/TILECOLOR/TILENAME$", GREEN, BLACK
1510 ELSE
1520 PRINTAT 2,R,"FAIL TILE/PLOT/TILECHAR/TILECOLOR/TILENAME$", RED, BLACK
1530 FAILS=FAILS+1
1540 ENDIF
1550 R=R+1
1560 DRAWSTR 0,R,"PASS DRAWSTR ALIAS", GREEN, BLACK
1570 R=R+1
1580 BOX 0,R,5,R+2,35, YELLOW, BLACK
1590 FILL 1,R+1,4,R+1,46, BLUE, BLACK
1600 HLINE 7,10,R,45, CYAN, BLACK
1610 VLINE 12,R,R+2,124, MAGENTA, BLACK
1620 BC1=TILECHAR(0,R)
1630 FC1=TILECHAR(2,R+1)
1640 HC1=TILECHAR(8,R)
1650 VC1=TILECHAR(12,R+1)
1660 IF BC1=35 AND FC1=46 AND HC1=45 AND VC1=124 THEN
1670 PRINTAT 14,R,"PASS BOX/FILL/HLINE/VLINE", GREEN, BLACK
1680 ELSE
1690 PRINTAT 14,R,"FAIL BOX/FILL/HLINE/VLINE", RED, BLACK
1700 FAILS=FAILS+1
1710 ENDIF
1720 R=R+4
1730 PRINTAT 0,R,"SCROLL VISUAL CHECK NEXT ROW MOVES UP", WHITE, BLACK
1740 R=R+1
1750 PRINTAT 0,R,"ROW BEFORE SCROLL", WHITE, BLACK
1760 SCROLL UP,1
1770 PRINTAT 30,R-1,"PASS SCROLL UP CHECK", GREEN, BLACK
1780 R=R+1
1790 FONT "DEFAULT_16"
1800 PRINTAT 0,R,"PASS FONT DEFAULT_16 VISUAL CHECK", GREEN, BLACK
1810 R=R+1
1820 FONTSET "DEFAULT_16"
1830 PRINTAT 0,R,"PASS FONTSET DEFAULT_16 VISUAL CHECK", GREEN, BLACK
1840 R=R+1
1850 PRINTAT 0,R,"CHECK BEEP R0.05 SHOULD NOT CRASH", YELLOW, BLACK
1860 BEEP R0.05
1870 R=R+1
1880 K$=INKEY$+""
1890 IF LEN(K$)>=0 THEN
1900 PRINTAT 0,R,"PASS INKEY$ EXPRESSION NONBLOCKING", GREEN, BLACK
1910 ELSE
1920 PRINTAT 0,R,"FAIL INKEY$ EXPRESSION NONBLOCKING", RED, BLACK
1930 FAILS=FAILS+1
1940 ENDIF
1950 R=R+1
1960 PRINTAT 0,R,"MANUAL/EDITOR COMMANDS NOT RUN IN PROGRAM: LIST RUN NEW SAVE LOAD DIR HELP PASTE LOADURL SCREENEDIT QUIT", YELLOW, BLACK
1970 R=R+1
1980 PRINTAT 0,R,"MANUAL INPUT/PAUSE TESTS KEPT SEPARATE", YELLOW, BLACK
1990 R=R+1
2000 PRINTAT 0,R,"FAILS="+STR$(FAILS), WHITE, BLACK
2010 R=R+1
2020 IF FAILS=0 THEN
2030 PRINTAT 0,R,"AUTOTEST PASS - MODE 2 TILE INVENTORY", GREEN, BLACK
2040 ELSE
2050 PRINTAT 0,R,"AUTOTEST FAIL - MODE 2 TILE INVENTORY", RED, BLACK
2060 ENDIF
2070 END
9000 DATA 7,"OK"
9010 DATA @NUMS: 3,4
9200 SUBOK=1
9210 RETURN
