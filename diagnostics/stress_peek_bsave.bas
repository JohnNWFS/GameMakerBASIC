10 REM ============================================================
20 REM BSAVE / BLOAD virtual PEEK map round-trip
30 REM ============================================================
40 CLS
50 PRINT "PEEK BSAVE/BLOAD TEST"
60 PRINT "====================="
70 PRINT ""
80 POKE 1000, 65
90 POKE 1001, 66
100 POKE 1002, 67
110 POKE 1003, 0
120 BSAVE "peek_autotest", 1000, 4
130 POKE 1000, 0
140 POKE 1001, 0
150 POKE 1002, 0
160 POKE 1003, 255
170 BLOAD "peek_autotest", 1000
180 IF PEEK(1000) = 65 THEN PRINT "TEST: BLOAD_B0 = PASS" ELSE PRINT "TEST: BLOAD_B0 = FAIL"
190 IF PEEK(1001) = 66 THEN PRINT "TEST: BLOAD_B1 = PASS" ELSE PRINT "TEST: BLOAD_B1 = FAIL"
200 IF PEEK(1002) = 67 THEN PRINT "TEST: BLOAD_B2 = PASS" ELSE PRINT "TEST: BLOAD_B2 = FAIL"
210 IF PEEK(1003) = 0 THEN PRINT "TEST: BLOAD_ZERO = PASS" ELSE PRINT "TEST: BLOAD_ZERO = FAIL"
220 SCORE = 50000
230 POKE 2000, SCORE \ 256
240 POKE 2001, SCORE MOD 256
250 BSAVE "peek_score", 2000, 2
260 POKE 2000, 0
270 POKE 2001, 0
280 BLOAD "peek_score", 2000
290 HI = PEEK(2000) * 256 + PEEK(2001)
300 IF HI = 50000 THEN PRINT "TEST: BSAVE_PACKED = PASS" ELSE PRINT "TEST: BSAVE_PACKED = FAIL ("; HI; ")"
310 PRINT ""
320 PRINT "BSAVE/BLOAD TEST COMPLETE"
330 END