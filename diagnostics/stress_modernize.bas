10 REM ============================================================
20 REM NW-BASIC STRESS TEST — modernization / regression
30 REM Targets: native arrays, struct variables, control flow
40 REM Output:  TEST: name = PASS  or  TEST: name = FAIL
50 REM Paste into editor, NEW if needed, RUN
60 REM ============================================================
70 CLS
80 PRINT "NW-BASIC STRESS TEST (modernize)"
90 PRINT "================================="
100 PRINT ""
110 REM
200 REM --- SECTION 1: MATH / OPS (sanity) ---
210 PRINT "SECTION 1: Math"
220 X = 2 + 3 * 4
230 IF X = 14 THEN PRINT "TEST: PRECEDENCE = PASS" ELSE PRINT "TEST: PRECEDENCE = FAIL"
240 X = (2 + 3) * 4
250 IF X = 20 THEN PRINT "TEST: PARENS = PASS" ELSE PRINT "TEST: PARENS = FAIL"
260 X = 17 \ 5
270 IF X = 3 THEN PRINT "TEST: INTDIV = PASS" ELSE PRINT "TEST: INTDIV = FAIL"
280 X = 17 MOD 5
290 IF X = 2 THEN PRINT "TEST: MOD = PASS" ELSE PRINT "TEST: MOD = FAIL"
300 X = 2 ^ 10
310 IF X = 1024 THEN PRINT "TEST: POW = PASS" ELSE PRINT "TEST: POW = FAIL"
320 PRINT ""
330 REM
400 REM --- SECTION 2: VARIABLE STORE (struct) ---
410 PRINT "SECTION 2: Variables"
420 NUM = 12345
430 IF NUM = 12345 THEN PRINT "TEST: VAR_NUM = PASS" ELSE PRINT "TEST: VAR_NUM = FAIL"
440 MSG$ = "ALPHA"
450 IF MSG$ = "ALPHA" THEN PRINT "TEST: VAR_STR = PASS" ELSE PRINT "TEST: VAR_STR = FAIL"
460 MSG$ = MSG$ + "-" + "BETA"
470 IF MSG$ = "ALPHA-BETA" THEN PRINT "TEST: VAR_STR_CAT = PASS" ELSE PRINT "TEST: VAR_STR_CAT = FAIL"
480 LET NUM = NUM + 5
490 IF NUM = 12350 THEN PRINT "TEST: LET = PASS" ELSE PRINT "TEST: LET = FAIL"
500 UNDECL = 99
510 IF UNDECL = 99 THEN PRINT "TEST: IMPLICIT_VAR = PASS" ELSE PRINT "TEST: IMPLICIT_VAR = FAIL"
520 PRINT ""
530 REM
600 REM --- SECTION 3: 1D ARRAYS (native GML backing) ---
610 PRINT "SECTION 3: 1D Arrays"
620 DIM N(20)
630 N(1) = 111
640 N(10) = 1010
650 N(20) = 2020
660 IF N(1) = 111 THEN PRINT "TEST: ARR1D_LO = PASS" ELSE PRINT "TEST: ARR1D_LO = FAIL"
670 IF N(10) = 1010 THEN PRINT "TEST: ARR1D_MID = PASS" ELSE PRINT "TEST: ARR1D_MID = FAIL"
680 IF N(20) = 2020 THEN PRINT "TEST: ARR1D_HI = PASS" ELSE PRINT "TEST: ARR1D_HI = FAIL"
690 DIM S$(8)
700 S$(1) = "ONE"
710 S$(8) = "EIGHT"
720 IF S$(1) = "ONE" THEN PRINT "TEST: ARRSTR_LO = PASS" ELSE PRINT "TEST: ARRSTR_LO = FAIL"
730 IF S$(8) = "EIGHT" THEN PRINT "TEST: ARRSTR_HI = PASS" ELSE PRINT "TEST: ARRSTR_HI = FAIL"
740 N(5) = N(1) + N(10)
750 IF N(5) = 1121 THEN PRINT "TEST: ARR_EXPR = PASS" ELSE PRINT "TEST: ARR_EXPR = FAIL"
760 PRINT ""
770 REM
800 REM --- SECTION 4: 2D ARRAYS ---
810 PRINT "SECTION 4: 2D Arrays"
820 DIM G(5,5)
830 FOR ROW = 1 TO 5
840   FOR COL = 1 TO 5
850     G(ROW,COL) = ROW * 10 + COL
860   NEXT COL
870 NEXT ROW
880 IF G(1,1) = 11 THEN PRINT "TEST: ARR2D_11 = PASS" ELSE PRINT "TEST: ARR2D_11 = FAIL"
890 IF G(3,4) = 34 THEN PRINT "TEST: ARR2D_34 = PASS" ELSE PRINT "TEST: ARR2D_34 = FAIL"
900 IF G(5,5) = 55 THEN PRINT "TEST: ARR2D_55 = PASS" ELSE PRINT "TEST: ARR2D_55 = FAIL"
905 ROW = 3 : COL = 4
906 IF G(ROW,COL) = 34 THEN PRINT "TEST: ARR2D_VARIDX = PASS" ELSE PRINT "TEST: ARR2D_VARIDX = FAIL"
910 SUM2D = 0
920 FOR ROW = 1 TO 5
930   FOR COL = 1 TO 5
940     SUM2D = SUM2D + G(ROW,COL)
950   NEXT COL
960 NEXT ROW
970 IF SUM2D = 825 THEN PRINT "TEST: ARR2D_SUM = PASS" ELSE PRINT "TEST: ARR2D_SUM = FAIL ("; SUM2D; ")"
980 PRINT ""
990 REM
1000 REM --- SECTION 5: LARGE 1D FILL (memory / resize stress) ---
1010 PRINT "SECTION 5: Large array fill"
1020 DIM BIG(100)
1030 FOR I = 1 TO 100
1040   BIG(I) = I * I
1050 NEXT I
1060 IF BIG(1) = 1 THEN PRINT "TEST: BIG_LO = PASS" ELSE PRINT "TEST: BIG_LO = FAIL"
1070 IF BIG(50) = 2500 THEN PRINT "TEST: BIG_MID = PASS" ELSE PRINT "TEST: BIG_MID = FAIL"
1080 IF BIG(100) = 10000 THEN PRINT "TEST: BIG_HI = PASS" ELSE PRINT "TEST: BIG_HI = FAIL"
1090 CHK = 0
1100 FOR I = 1 TO 100
1110   CHK = CHK + BIG(I)
1120 NEXT I
1130 IF CHK = 338350 THEN PRINT "TEST: BIG_SUM = PASS" ELSE PRINT "TEST: BIG_SUM = FAIL"
1140 PRINT ""
1150 REM
1200 REM --- SECTION 6: FOR / NEXT stress ---
1210 PRINT "SECTION 6: FOR/NEXT"
1220 SUM = 0
1230 FOR I = 1 TO 50
1240   SUM = SUM + 1
1250 NEXT I
1260 IF SUM = 50 THEN PRINT "TEST: FOR_50 = PASS" ELSE PRINT "TEST: FOR_50 = FAIL"
1270 PROD = 1
1280 FOR I = 1 TO 8
1290   PROD = PROD * 2
1300 NEXT I
1310 IF PROD = 256 THEN PRINT "TEST: FOR_POW2 = PASS" ELSE PRINT "TEST: FOR_POW2 = FAIL"
1320 SUM = 0
1330 FOR I = 20 TO 1 STEP -1
1340   SUM = SUM + I
1350 NEXT I
1360 IF SUM = 210 THEN PRINT "TEST: FOR_STEP_NEG = PASS" ELSE PRINT "TEST: FOR_STEP_NEG = FAIL"
1370 PRINT ""
1380 REM
1400 REM --- SECTION 7: WHILE / WEND ---
1410 PRINT "SECTION 7: WHILE/WEND"
1420 X = 1
1430 SUM = 0
1440 WHILE X <= 25
1450   SUM = SUM + X
1460   X = X + 1
1470 WEND
1480 IF SUM = 325 THEN PRINT "TEST: WHILE_25 = PASS" ELSE PRINT "TEST: WHILE_25 = FAIL"
1490 PRINT ""
1500 REM
1600 REM --- SECTION 8: GOSUB / RETURN ---
1610 PRINT "SECTION 8: GOSUB"
1620 GOSUB 9000
1630 IF SUBOK = 1 THEN PRINT "TEST: GOSUB = PASS" ELSE PRINT "TEST: GOSUB = FAIL"
1640 PRINT ""
1650 REM
1700 REM --- SECTION 9: BLOCK IF ---
1710 PRINT "SECTION 9: Block IF"
1720 X = 7
1730 IF X > 5 THEN
1740   Y = 42
1750 ELSE
1760   Y = 0
1770 ENDIF
1780 IF Y = 42 THEN PRINT "TEST: BLOCK_IF = PASS" ELSE PRINT "TEST: BLOCK_IF = FAIL"
1790 X = 2
1800 IF X < 5 THEN
1810   Y = 100
1820 ELSEIF X < 10 THEN
1830   Y = 200
1840 ELSE
1850   Y = 300
1860 ENDIF
1870 IF Y = 100 THEN PRINT "TEST: BLOCK_ELSEIF = PASS" ELSE PRINT "TEST: BLOCK_ELSEIF = FAIL"
1880 PRINT ""
1890 REM
1900 REM --- SECTION 10: STRINGS ---
1910 PRINT "SECTION 10: Strings"
1920 A$ = "HELLO"
1930 B$ = "WORLD"
1940 C$ = A$ + " " + B$
1950 IF C$ = "HELLO WORLD" THEN PRINT "TEST: STR_CAT = PASS" ELSE PRINT "TEST: STR_CAT = FAIL"
1960 IF LEN(C$) = 11 THEN PRINT "TEST: LEN = PASS" ELSE PRINT "TEST: LEN = FAIL"
1970 IF LEFT$(C$,5) = "HELLO" THEN PRINT "TEST: LEFT$ = PASS" ELSE PRINT "TEST: LEFT$ = FAIL"
1980 IF RIGHT$(C$,5) = "WORLD" THEN PRINT "TEST: RIGHT$ = PASS" ELSE PRINT "TEST: RIGHT$ = FAIL"
1990 IF MID$(C$,7,5) = "WORLD" THEN PRINT "TEST: MID$ = PASS" ELSE PRINT "TEST: MID$ = FAIL"
2000 IF UCASE$("abc") = "ABC" THEN PRINT "TEST: UCASE$ = PASS" ELSE PRINT "TEST: UCASE$ = FAIL"
2010 IF VAL("9876") = 9876 THEN PRINT "TEST: VAL = PASS" ELSE PRINT "TEST: VAL = FAIL"
2020 PRINT ""
2030 REM
2100 REM --- SECTION 11: DATA / READ ---
2110 PRINT "SECTION 11: DATA/READ"
2120 RESTORE
2130 READ D1, D2, D3$
2140 IF D1 = 10 AND D2 = 20 AND D3$ = "ZED" THEN PRINT "TEST: DATA_READ = PASS" ELSE PRINT "TEST: DATA_READ = FAIL"
2150 PRINT ""
2160 DATA 10, 20, "ZED"
2170 REM
2200 REM --- SECTION 12: MULTI-STATEMENT LINES ---
2210 PRINT "SECTION 12: Colon statements"
2220 X = 0 : Y = 0 : Z = 0
2230 X = 1 : Y = 2 : Z = 3
2240 IF X = 1 AND Y = 2 AND Z = 3 THEN PRINT "TEST: COLON = PASS" ELSE PRINT "TEST: COLON = FAIL"
2250 PRINT ""
2260 REM
2300 REM --- SECTION 13: NESTED ARRAY + VARS IN LOOP ---
2310 PRINT "SECTION 13: Nested loop + arrays"
2320 DIM ACC(10)
2330 FOR I = 1 TO 10
2340   ACC(I) = 0
2350 NEXT I
2360 FOR I = 1 TO 10
2370   FOR J = 1 TO I
2380     ACC(I) = ACC(I) + 1
2390   NEXT J
2400 NEXT I
2410 IF ACC(1) = 1 AND ACC(5) = 5 AND ACC(10) = 10 THEN PRINT "TEST: TRIANGLE = PASS" ELSE PRINT "TEST: TRIANGLE = FAIL"
2420 PRINT ""
2430 REM
8000 REM --- DONE ---
8010 PRINT "================================="
8020 PRINT "STRESS TEST COMPLETE"
8030 PRINT "Scan output for any FAIL lines."
8040 PRINT "================================="
8050 END
8060 REM
9000 REM GOSUB helper
9010 SUBOK = 1
9020 DIM SUBARR(3)
9030 SUBARR(1) = 7
9040 SUBARR(2) = 8
9050 SUBARR(3) = 15
9060 IF SUBARR(1) + SUBARR(2) = SUBARR(3) THEN SUBOK = 1 ELSE SUBOK = 0
9070 RETURN