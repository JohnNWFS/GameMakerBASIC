5 REM ============================================================
10 REM MODE 2 custom tile scene — build tileset, save, reload, draw
20 REM Simulates TILEEDIT-authored sprites via TILEPX, then TILELOAD
30 REM ============================================================
40 MODE 2, 16
50 CLSCHAR 32, WHITE, BLACK
60 PRINTAT 1, 0, "CUSTOM TILE SCENE (SAVE / LOAD)", YELLOW, BLACK
70 GOSUB 9000
80 TILESAVE "space_tiles"
90 TILERESTORE 200
100 TILERESTORE 201
110 TILERESTORE 202
120 TILERESTORE 203
130 TILERESTORE 204
140 IF TILEBIT(200, 8, 8) = 0 THEN PRINT "TEST: CLEARED_BEFORE_LOAD = PASS" ELSE PRINT "TEST: CLEARED_BEFORE_LOAD = FAIL"
150 TILELOAD "space_tiles"
160 IF TILEBIT(200, 8, 8) = 1 THEN PRINT "TEST: LOAD_STAR_CENTER = PASS" ELSE PRINT "TEST: LOAD_STAR_CENTER = FAIL"
170 IF TILEBIT(201, 7, 4) = 1 THEN PRINT "TEST: LOAD_SHIP_NOSE = PASS" ELSE PRINT "TEST: LOAD_SHIP_NOSE = FAIL"
180 GOSUB 8000
190 IF TILECHAR(18, 18) = 201 THEN PRINT "TEST: SHIP_ON_GRID = PASS" ELSE PRINT "TEST: SHIP_ON_GRID = FAIL"
200 IF TILECHAR(32, 3) = 202 THEN PRINT "TEST: PLANET_ON_GRID = PASS" ELSE PRINT "TEST: PLANET_ON_GRID = FAIL"
210 PRINTAT 1, 22, "ALT TILES FROM space_tiles.nwtile", GREEN, BLACK
220 PRINT ""
230 PRINT "CUSTOM TILE SCENE COMPLETE"
240 END

8000 REM -------- DRAW LOW-RES SCENE WITH LOADED TILES --------
8010 TILE 32, 3, 202, CYAN, BLACK
8020 TILE 36, 5, 203, WHITE, BLACK
8030 TILE 5, 2, 200, YELLOW, BLACK
8040 TILE 12, 4, 200, WHITE, BLACK
8050 TILE 28, 8, 200, YELLOW, BLACK
8060 TILE 35, 14, 200, WHITE, BLACK
8070 TILE 8, 16, 200, YELLOW, BLACK
8080 TILE 18, 18, 201, LIME, BLACK
8090 TILE 18, 19, 204, RED, BLACK
8100 PRINTAT 14, 16, "NW-BASIC", WHITE, BLACK
8110 RETURN

9000 REM -------- BUILD TILESET (stand-in for TILEEDIT painting) --------
9010 REM 200 = star, 201 = ship, 202 = planet, 203 = moon, 204 = flame
9020 TILEDEF 200, 16, 16
9030 FOR I = 6 TO 9
9040 TILEPX 200, I, 8, 1
9050 TILEPX 200, 8, I, 1
9060 NEXT I
9070 TILEDEF 201, 16, 16
9080 FOR I = 4 TO 11
9090 TILEPX 201, I, 14, 1
9100 NEXT I
9110 FOR I = 5 TO 10
9120 TILEPX 201, I, 13, 1
9130 TILEPX 201, I, 12, 1
9140 NEXT I
9150 FOR I = 6 TO 9
9160 TILEPX 201, I, 11, 1
9170 TILEPX 201, I, 10, 1
9180 TILEPX 201, I, 9, 1
9190 TILEPX 201, I, 8, 1
9200 TILEPX 201, I, 7, 1
9210 TILEPX 201, I, 6, 1
9220 TILEPX 201, I, 5, 1
9230 TILEPX 201, I, 4, 1
9240 NEXT I
9250 TILEPX 201, 7, 3, 1
9260 TILEPX 201, 8, 3, 1
9270 TILEDEF 202, 16, 16
9280 FOR Y = 2 TO 13
9290 FOR X = 2 TO 13
9300 IF (X - 7) * (X - 7) + (Y - 7) * (Y - 7) < 30 THEN TILEPX 202, X, Y, 1
9310 NEXT X
9320 NEXT Y
9330 TILEDEF 203, 16, 16
9340 FOR Y = 5 TO 10
9350 FOR X = 5 TO 10
9360 IF (X - 7) * (X - 7) + (Y - 7) * (Y - 7) < 8 THEN TILEPX 203, X, Y, 1
9370 NEXT X
9380 NEXT Y
9390 TILEDEF 204, 16, 16
9400 FOR I = 6 TO 9
9410 TILEPX 204, I, 12, 1
9420 TILEPX 204, I, 11, 1
9430 TILEPX 204, I, 10, 1
9440 NEXT I
9450 TILEPX 204, 7, 9, 1
9460 TILEPX 204, 8, 9, 1
9470 RETURN