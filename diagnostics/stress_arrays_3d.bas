10 REM ============================================================
20 REM NW-BASIC 3-D ARRAY smoke test
30 REM Integers, character codes (ASC/CHR$), and strings
40 REM ============================================================
50 CLS
60 PRINT "NW-BASIC 3-D ARRAY TEST"
70 PRINT "======================="
80 PRINT ""
90 DIM N(2, 3, 2)
100 DIM C(2, 2, 2)
110 DIM W$(2, 2, 2)
120 FOR I = 1 TO 2
130   FOR J = 1 TO 3
140     FOR K = 1 TO 2
150       N(I, J, K) = I * 100 + J * 10 + K
160     NEXT K
170   NEXT J
180 NEXT I
190 IF N(1, 1, 1) = 111 THEN PRINT "TEST: INT_CORNER_A = PASS" ELSE PRINT "TEST: INT_CORNER_A = FAIL"
200 IF N(2, 3, 2) = 232 THEN PRINT "TEST: INT_CORNER_B = PASS" ELSE PRINT "TEST: INT_CORNER_B = FAIL"
210 I = 2 : J = 3 : K = 1
220 IF N(I, J, K) = 231 THEN PRINT "TEST: INT_VARIDX = PASS" ELSE PRINT "TEST: INT_VARIDX = FAIL"
230 SUM3D = 0
240 FOR I = 1 TO 2
250   FOR J = 1 TO 3
260     FOR K = 1 TO 2
270       SUM3D = SUM3D + N(I, J, K)
280     NEXT K
290   NEXT J
300 NEXT I
310 IF SUM3D = 2058 THEN PRINT "TEST: INT_SUM = PASS" ELSE PRINT "TEST: INT_SUM = FAIL ("; SUM3D; ")"
320 C(1, 1, 1) = ASC("X")
330 C(1, 2, 2) = ASC("Y")
340 C(2, 2, 1) = ASC("Z")
350 IF CHR$(C(1, 1, 1)) = "X" THEN PRINT "TEST: CHR_STORE_A = PASS" ELSE PRINT "TEST: CHR_STORE_A = FAIL"
360 IF CHR$(C(1, 2, 2)) = "Y" THEN PRINT "TEST: CHR_STORE_B = PASS" ELSE PRINT "TEST: CHR_STORE_B = FAIL"
370 IF CHR$(C(2, 2, 1)) = "Z" THEN PRINT "TEST: CHR_STORE_C = PASS" ELSE PRINT "TEST: CHR_STORE_C = FAIL"
380 W$(1, 1, 1) = "cat"
390 W$(1, 2, 2) = "bat"
400 W$(2, 2, 2) = "dog"
410 IF W$(1, 1, 1) = "cat" THEN PRINT "TEST: STR_CORNER = PASS" ELSE PRINT "TEST: STR_CORNER = FAIL"
420 IF LEN(W$(2, 2, 2)) = 3 THEN PRINT "TEST: STR_LEN = PASS" ELSE PRINT "TEST: STR_LEN = FAIL"
430 IF W$(1, 2, 2) + "-" + W$(2, 2, 2) = "bat-dog" THEN PRINT "TEST: STR_CONCAT = PASS" ELSE PRINT "TEST: STR_CONCAT = FAIL"
440 ERASE C
450 DIM C(2, 2, 2)
460 C(2, 2, 2) = ASC("Q")
470 IF CHR$(C(2, 2, 2)) = "Q" THEN PRINT "TEST: ERASE_REDIM = PASS" ELSE PRINT "TEST: ERASE_REDIM = FAIL"
480 PRINT ""
490 PRINT "3-D ARRAY TEST COMPLETE"
500 END