10 REM ** YAHTZEE GAME FOR GAMEMAKER BASIC **
20 CLS : COLOR CYAN
30 PRINT "================================"
40 PRINT "           YAHTZEE"
50 PRINT "================================"
60 COLOR WHITE : PRINT
70 PRINT "Welcome to Yahtzee!"
80 PRINT "Press ENTER to start..."
90 K$ = INKEY$
100 GOTO 1000
110 REM
1000 REM ** INITIALIZE GAME **
1010 DIM DICE(5)
1020 DIM HOLD(5)
1030 DIM SCORES(13)
1040 DIM SCORED(13)
1050 DIM COUNT(6)
1060 ROUND = 1
1070 TOTAL_SCORE = 0
1080 REM Initialize arrays
1090 FOR I = 1 TO 5
1100   DICE(I) = 0
1110   HOLD(I) = 0
1120 NEXT I
1130 FOR I = 1 TO 13
1140   SCORES(I) = 0
1150   SCORED(I) = 0
1160 NEXT I
1170 REM Start main game loop
1180 FOR ROUND = 1 TO 13
1190   GOSUB 2000
1200 NEXT ROUND
1210 GOSUB 9000
1220 END
2000 REM ** PLAY ONE ROUND **
2010 CLS : COLOR YELLOW
2020 PRINT "ROUND "; ROUND; " OF 13"
2030 PRINT "=================="
2040 COLOR WHITE
2050 REM Reset holds for new round
2060 FOR I = 1 TO 5
2070   HOLD(I) = 0
2080 NEXT I
2090 REM Three rolls per round
2100 FOR ROLL_NUM = 1 TO 3
2110   GOSUB 3000
2120   GOSUB 4000
2130   IF ROLL_NUM < 3 THEN GOSUB 5000
2140 NEXT ROLL_NUM
2150 GOSUB 6000
2160 RETURN
3000 REM ** ROLL DICE **
3010 FOR I = 1 TO 5
3020   IF HOLD(I) = 0 THEN DICE(I) = RND(6)
3030 NEXT I
3040 RETURN
4000 REM ** DISPLAY DICE **
4010 PRINT
4020 PRINT "Your dice:"
4030 FOR I = 1 TO 5
4040   PRINT "["; DICE(I); "]";
4050   IF HOLD(I) = 1 THEN PRINT "H"; ELSE PRINT " ";
4060 NEXT I
4070 PRINT
4080 IF ROLL_NUM < 3 THEN PRINT "(H = Held for next roll)"
4090 RETURN
5000 REM ** SELECT DICE TO HOLD **
5010 PRINT
5020 PRINT "Roll "; ROLL_NUM; " of 3"
5030 PRINT "Enter dice to HOLD (1-5) or ENTER for none:"
5040 INPUT "Dice: ", HOLD_INPUT$
5050 IF HOLD_INPUT$ = "" THEN RETURN
5060 FOR I = 1 TO LEN(HOLD_INPUT$)
5070   CH$ = MID$(HOLD_INPUT$, I, 1)
5080   POS = 0
5090   IF CH$ = "1" THEN POS = 1
5100   IF CH$ = "2" THEN POS = 2
5110   IF CH$ = "3" THEN POS = 3
5120   IF CH$ = "4" THEN POS = 4
5130   IF CH$ = "5" THEN POS = 5
5140   IF POS >= 1 AND POS <= 5 THEN
5150     HOLD(POS) = 1
5160   ENDIF
5170 NEXT I
5180 RETURN
6000 REM ** CHOOSE SCORING CATEGORY **
6010 GOSUB 7000
6020 PRINT
6030 COLOR YELLOW
6040 PRINT "Choose a scoring category (1-13):"
6050 COLOR WHITE
6060 INPUT "Category: ", CAT
6070 IF CAT < 1 OR CAT > 13 THEN PRINT "Invalid category!"
6071 IF CAT < 1 OR CAT > 13 THEN  GOTO 6060
6080 '
6090 GOSUB 8000
6100 SCORES(CAT) = CALC_SCORE
6110 SCORED(CAT) = 1
6120 TOTAL_SCORE = TOTAL_SCORE + CALC_SCORE
6130 COLOR GREEN
6140 PRINT "Scored "; CALC_SCORE; " points!"
6150 COLOR WHITE
6160 PRINT "Press ENTER to continue..."
6170 K$ = INKEY$
6180 RETURN
7000 REM ** SHOW SCORECARD **
7010 COLOR CYAN
7020 PRINT
7030 PRINT "SCORECARD:"
7040 PRINT "=========="
7050 COLOR WHITE
7060 PRINT " 1. Ones        :";
7070 IF SCORED(1) = 1 THEN PRINT SCORES(1) ELSE PRINT " ---"
7080 PRINT " 2. Twos        :";
7090 IF SCORED(2) = 1 THEN PRINT SCORES(2) ELSE PRINT " ---"
7100 PRINT " 3. Threes      :";
7110 IF SCORED(3) = 1 THEN PRINT SCORES(3) ELSE PRINT " ---"
7120 PRINT " 4. Fours       :";
7130 IF SCORED(4) = 1 THEN PRINT SCORES(4) ELSE PRINT " ---"
7140 PRINT " 5. Fives       :";
7150 IF SCORED(5) = 1 THEN PRINT SCORES(5) ELSE PRINT " ---"
7160 PRINT " 6. Sixes       :";
7170 IF SCORED(6) = 1 THEN PRINT SCORES(6) ELSE PRINT " ---"
7180 PRINT " 7. 3 of a Kind :";
7190 IF SCORED(7) = 1 THEN PRINT SCORES(7) ELSE PRINT " ---"
7200 PRINT " 8. 4 of a Kind :";
7210 IF SCORED(8) = 1 THEN PRINT SCORES(8) ELSE PRINT " ---"
7220 PRINT " 9. Full House  :";
7230 IF SCORED(9) = 1 THEN PRINT SCORES(9) ELSE PRINT " ---"
7240 PRINT "10. Small Straight:";
7250 IF SCORED(10) = 1 THEN PRINT SCORES(10) ELSE PRINT " ---"
7260 PRINT "11. Large Straight:";
7270 IF SCORED(11) = 1 THEN PRINT SCORES(11) ELSE PRINT " ---"
7280 PRINT "12. Yahtzee     :";
7290 IF SCORED(12) = 1 THEN PRINT SCORES(12) ELSE PRINT " ---"
7300 PRINT "13. Chance      :";
7310 IF SCORED(13) = 1 THEN PRINT SCORES(13) ELSE PRINT " ---"
7320 RETURN
8000 REM ** CALCULATE SCORE FOR CATEGORY **
8010 CALC_SCORE = 0
8020 IF CAT >= 1 AND CAT <= 6 THEN GOTO 8100
8030 IF CAT = 7 THEN GOTO 8200
8040 IF CAT = 8 THEN GOTO 8300
8050 IF CAT = 9 THEN GOTO 8400
8060 IF CAT = 10 THEN GOTO 8500
8070 IF CAT = 11 THEN GOTO 8600
8080 IF CAT = 12 THEN GOTO 8700
8090 IF CAT = 13 THEN GOTO 8800
8095 RETURN
8100 REM ** SCORE NUMBERS (1-6) **
8110 FOR I = 1 TO 5
8120   IF DICE(I) = CAT THEN CALC_SCORE = CALC_SCORE + CAT
8130 NEXT I
8140 RETURN
8200 REM ** SCORE 3 OF A KIND **
8210 GOSUB 8900
8220 FOR I = 1 TO 6
8230   IF COUNT(I) >= 3 THEN
8240     FOR J = 1 TO 5
8250       CALC_SCORE = CALC_SCORE + DICE(J)
8260     NEXT J
8270     RETURN
8280   ENDIF
8290 NEXT I
8300 REM ** SCORE 4 OF A KIND **
8310 GOSUB 8900
8320 FOR I = 1 TO 6
8330   IF COUNT(I) >= 4 THEN
8340     FOR J = 1 TO 5
8350       CALC_SCORE = CALC_SCORE + DICE(J)
8360     NEXT J
8370     RETURN
8380   ENDIF
8390 NEXT I
8400 REM ** SCORE FULL HOUSE **
8410 GOSUB 8900
8420 HAS_THREE = 0
8430 HAS_TWO = 0
8440 FOR I = 1 TO 6
8450   IF COUNT(I) = 3 THEN HAS_THREE = 1
8460   IF COUNT(I) = 2 THEN HAS_TWO = 1
8470 NEXT I
8480 IF HAS_THREE = 1 AND HAS_TWO = 1 THEN CALC_SCORE = 25
8490 RETURN
8500 REM ** SCORE SMALL STRAIGHT **
8510 GOSUB 8900
8520 REM Check for 1234, 2345, 3456
8530 IF COUNT(1) > 0 AND COUNT(2) > 0 AND COUNT(3) > 0 AND COUNT(4) > 0 THEN CALC_SCORE = 30
8540 IF COUNT(2) > 0 AND COUNT(3) > 0 AND COUNT(4) > 0 AND COUNT(5) > 0 THEN CALC_SCORE = 30
8550 IF COUNT(3) > 0 AND COUNT(4) > 0 AND COUNT(5) > 0 AND COUNT(6) > 0 THEN CALC_SCORE = 30
8560 RETURN
8600 REM ** SCORE LARGE STRAIGHT **
8610 GOSUB 8900
8620 REM Check for 12345, 23456
8630 IF COUNT(1) > 0 AND COUNT(2) > 0 AND COUNT(3) > 0 AND COUNT(4) > 0 AND COUNT(5) > 0 THEN CALC_SCORE = 40
8640 IF COUNT(2) > 0 AND COUNT(3) > 0 AND COUNT(4) > 0 AND COUNT(5) > 0 AND COUNT(6) > 0 THEN CALC_SCORE = 40
8650 RETURN
8700 REM ** SCORE YAHTZEE **
8710 GOSUB 8900
8720 FOR I = 1 TO 6
8730   IF COUNT(I) = 5 THEN CALC_SCORE = 50
8740 NEXT I
8750 RETURN
8800 REM ** SCORE CHANCE **
8810 FOR I = 1 TO 5
8820   CALC_SCORE = CALC_SCORE + DICE(I)
8830 NEXT I
8840 RETURN
8900 REM ** COUNT DICE VALUES **
8910 FOR I = 1 TO 6
8920   COUNT(I) = 0
8930 NEXT I
8940 FOR I = 1 TO 5
8950   COUNT(DICE(I)) = COUNT(DICE(I)) + 1
8960 NEXT I
8970 RETURN
9000 REM ** SHOW FINAL SCORE **
9010 CLS : COLOR CYAN
9020 PRINT "================================"
9030 PRINT "         FINAL SCORE"
9040 PRINT "================================"
9050 GOSUB 7000
9060 COLOR YELLOW
9070 PRINT
9080 PRINT "TOTAL SCORE: "; TOTAL_SCORE
9090 PRINT
9100 IF TOTAL_SCORE >= 300 THEN COLOR GREEN : PRINT "EXCELLENT GAME!"
9110 IF TOTAL_SCORE >= 200 AND TOTAL_SCORE < 300 THEN COLOR CYAN : PRINT "GOOD GAME!"
9120 IF TOTAL_SCORE < 200 THEN COLOR WHITE : PRINT "BETTER LUCK NEXT TIME!"
9130 COLOR WHITE
9140 PRINT
9150 PRINT "Thanks for playing Yahtzee!"
9160 RETURN
