5 REM ============================================================
10 REM MODE 2 tile map smoke — MAPNEW/MAPSET/MAPDRAW/MAPSAVE/MAPLOAD
20 REM ============================================================
30 MODE 2,16
40 CLSCHAR 32, WHITE, BLACK
50 MAPNEW 40, 24, "room"
60 FOR X = 0 TO 39
70 MAPSET X, 0, 35
80 MAPSET X, 23, 35
90 NEXT X
100 FOR Y = 0 TO 23
110 MAPSET 0, Y, 35
120 MAPSET 39, Y, 35
130 NEXT Y
140 MAPSET 20, 12, 42, YELLOW, BLACK
150 MAPDRAW 0, 0
160 IF TILECHAR(0, 0) = 35 THEN PRINT "TEST: MAP_BORDER_TL = PASS" ELSE PRINT "TEST: MAP_BORDER_TL = FAIL"
170 IF TILECHAR(39, 23) = 35 THEN PRINT "TEST: MAP_BORDER_BR = PASS" ELSE PRINT "TEST: MAP_BORDER_BR = FAIL"
180 IF TILECHAR(20, 12) = 42 THEN PRINT "TEST: MAP_CENTER_STAR = PASS" ELSE PRINT "TEST: MAP_CENTER_STAR = FAIL"
190 MAPSAVE "map_smoke_room"
200 CLSCHAR 32, WHITE, BLACK
210 MAPLOAD "map_smoke_room"
220 MAPDRAW 0, 0
230 IF TILECHAR(20, 12) = 42 THEN PRINT "TEST: MAP_LOAD_DRAW = PASS" ELSE PRINT "TEST: MAP_LOAD_DRAW = FAIL"
240 PRINT ""
250 PRINT "TILE MAP SMOKE COMPLETE"
260 END