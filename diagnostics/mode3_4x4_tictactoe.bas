130 IF W<>0 THEN GOTO 900
140 IF MOVES>=16 THEN GOTO 950
150 INPUT "MOVE 1-16 (0=QUIT): ", M
160 IF M=0 THEN GOTO 990
170 IF M<1 OR M>16 THEN
171 MSG$="PICK 1 THROUGH 16."
172 GOTO 120
173 ENDIF
180 IF B(M)<>0 THEN
181 MSG$="THAT SQUARE IS TAKEN."
182 GOTO 120
183 ENDIF
190 B(M)=1
200 MOVES=MOVES+1
210 P=1
220 GOSUB 6000
230 IF W=1 THEN
231 MSG$="YOU WIN!"
232 GOTO 120
233 ENDIF
240 IF MOVES>=16 THEN GOTO 120
