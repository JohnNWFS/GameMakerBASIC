5 REM AUTOTEST_SCREENSHOT
10 REM ============================================================
20 REM NW-BASIC MODE 2 GRID TEST — native 2D array (Phase 2)
30 REM Targets: MODE 2, CHARAT, PRINTAT, TILE/PLOT, readback,
40 REM          BOX/FILL/HLINE/VLINE, CLSCHAR, SCROLL, TILECHAR sum
50 REM Output on tile grid:  TEST: name = PASS  or  FAIL
60 REM Paste into editor, RUN (switches to MODE 2 graphics room)
70 REM ============================================================
80 MODE 2,16
90 CLSCHAR 32, WHITE, BLACK
100 R = 1
110 PRINTAT 0, 0, "NW-BASIC MODE 2 GRID TEST (Phase 2)", YELLOW, BLACK
120 PRINTAT 0, R, "===================================", CYAN, BLACK
130 R = R + 2
140 REM
200 REM --- SECTION 1: MODE 2 active ---
210 PRINTAT 0, R, "SECTION 1: MODE switch", WHITE, BLACK
220 R = R + 1
230 IF SCREEN() = 2 THEN PRINTAT 0, R, "TEST: MODE2 = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: MODE2 = FAIL", RED, BLACK
240 R = R + 2
250 REM
300 REM --- SECTION 2: CHARAT + TILECHAR readback ---
310 PRINTAT 0, R, "SECTION 2: CHARAT readback", WHITE, BLACK
320 R = R + 1
330 CHARAT 5, 5, 65
340 IF TILECHAR(5, 5) = 65 THEN PRINTAT 0, R, "TEST: CHARAT_TILE = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: CHARAT_TILE = FAIL", RED, BLACK
350 R = R + 1
360 CX = 12 : CY = 14
370 CHARAT CX, CY, 88
380 IF TILECHAR(CX, CY) = 88 THEN PRINTAT 0, R, "TEST: CHARAT_VAR = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: CHARAT_VAR = FAIL", RED, BLACK
390 R = R + 2
400 REM
500 REM --- SECTION 3: PRINTAT + MODE1_GET_CHAR ---
510 PRINTAT 0, R, "SECTION 3: PRINTAT", WHITE, BLACK
520 R = R + 1
530 PRINTAT 2, R, "Z", MAGENTA, BLACK
540 IF MODE1_GET_CHAR(2, R) = 90 THEN PRINTAT 0, R, "TEST: PRINTAT_GET = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: PRINTAT_GET = FAIL", RED, BLACK
550 R = R + 2
560 REM
600 REM --- SECTION 4: TILE / PLOT aliases + color read ---
610 PRINTAT 0, R, "SECTION 4: TILE PLOT colors", WHITE, BLACK
620 R = R + 1
630 TILE 8, R, 67, RED, BLACK
640 PLOT 9, R, 68, GREEN, BLACK
650 IF TILECHAR(8, R) = 67 THEN PRINTAT 0, R, "TEST: TILE_CHAR = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: TILE_CHAR = FAIL", RED, BLACK
660 R = R + 1
670 IF TILENAME$(TILECOLOR(9, R)) = "GREEN" THEN PRINTAT 0, R, "TEST: TILE_COLOR = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: TILE_COLOR = FAIL", RED, BLACK
680 R = R + 2
690 REM
700 REM --- SECTION 5: BOX FILL HLINE VLINE ---
710 PRINTAT 0, R, "SECTION 5: Region draw", WHITE, BLACK
720 R = R + 1
730 BOX 0, R, 5, R + 2, 35, YELLOW, BLACK
740 FILL 1, R + 1, 4, R + 1, 46, BLUE, BLACK
750 HLINE 7, 10, R, 45, CYAN, BLACK
760 VLINE 12, R, R + 2, 124, MAGENTA, BLACK
770 IF TILECHAR(0, R) = 35 AND TILECHAR(2, R + 1) = 46 AND TILECHAR(8, R) = 45 AND TILECHAR(12, R + 1) = 124 THEN PRINTAT 0, R + 3, "TEST: REGION_DRAW = PASS", GREEN, BLACK ELSE PRINTAT 0, R + 3, "TEST: REGION_DRAW = FAIL", RED, BLACK
780 R = R + 5
790 REM
800 REM --- SECTION 6: 2D grid stress (3x3 digit fill) ---
810 PRINTAT 0, R, "SECTION 6: 2D grid stress", WHITE, BLACK
820 R = R + 1
830 BASEC = 20 : BASER = R
840 SUM = 0
850 FOR ROW = 1 TO 3
860   FOR COL = 1 TO 3
870     CH = 48 + (ROW - 1) * 3 + COL
880     CHARAT BASEC + COL, BASER + ROW, CH
890     SUM = SUM + TILECHAR(BASEC + COL, BASER + ROW)
900   NEXT COL
910 NEXT ROW
920 IF SUM = 45 THEN PRINTAT 0, R + 5, "TEST: GRID2D_SUM = PASS", GREEN, BLACK ELSE PRINTAT 0, R + 5, "TEST: GRID2D_SUM = FAIL (" + STR$(SUM) + ")", RED, BLACK
930 R = R + 7
940 REM
1000 REM --- SECTION 7: SCROLL UP (before CLSCHAR wipes grid) ---
1010 PRINTAT 0, R, "SECTION 7: SCROLL", WHITE, BLACK
1020 R = R + 1
1030 MARK = 113
1040 SR = R + 4
1050 CHARAT 0, SR, MARK
1060 SCROLL UP, 1
1070 IF TILECHAR(0, SR - 1) = MARK THEN PRINTAT 0, R, "TEST: SCROLL_UP = PASS", GREEN, BLACK ELSE PRINTAT 0, R, "TEST: SCROLL_UP = FAIL", RED, BLACK
1080 R = R + 2
1090 REM
1100 REM --- SECTION 8: CLSCHAR full-grid fill (wipes display) ---
1110 PRINTAT 0, R, "SECTION 8: CLSCHAR", WHITE, BLACK
1120 R = R + 1
1130 CLSCHAR 46, BLUE, BLACK
1140 IF TILECHAR(5, 5) = 46 AND TILECHAR(12, 14) = 46 THEN PRINTAT 0, 1, "TEST: CLSCHAR = PASS", GREEN, BLACK ELSE PRINTAT 0, 1, "TEST: CLSCHAR = FAIL", RED, BLACK
1150 PRINTAT 0, 0, "NW-BASIC MODE 2 GRID TEST (Phase 2)", YELLOW, BLACK
1160 PRINTAT 0, 2, "MODE 2 GRID TEST COMPLETE", CYAN, BLACK
1170 PRINTAT 0, 3, "CLSCHAR cleared grid; PASS/FAIL on rows 0-2", WHITE, BLACK
1180 END