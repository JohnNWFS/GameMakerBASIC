5 REM ============================================================
10 REM NOT PLAYABLE — init/render smoke for Crystal Caves
20 REM For the game, run mode2_adventure_poc.bas instead
30 REM ============================================================
40 MODE 2, 32
50 CLSCHAR 32, WHITE, BLACK
60 GOSUB 9000
70 IF TILEBIT(200, 15, 12) = 1 THEN PRINT "TEST: HERO_TILE = PASS" ELSE PRINT "TEST: HERO_TILE = FAIL"
80 GOSUB 8000
90 VIEW 0, 2, 38, 18
100 PX = 4
110 PY = 4
120 CAMX = 0
130 CAMY = 0
140 GOSUB 6000
150 IF TILECHAR(9, 8) = 201 THEN PRINT "TEST: TREE_VISIBLE = PASS" ELSE PRINT "TEST: TREE_VISIBLE = FAIL"
160 IF TILECHAR(5, 6) = 46 THEN PRINT "TEST: FLOOR_VISIBLE = PASS" ELSE PRINT "TEST: FLOOR_VISIBLE = FAIL"
170 IF TILECHAR(4, 6) = 200 THEN PRINT "TEST: HERO_DRAWN = PASS" ELSE PRINT "TEST: HERO_DRAWN = FAIL"
180 T0 = TIMER
190 FOR I = 1 TO 5
200 GOSUB 6000
210 NEXT I
220 T1 = TIMER
230 DT = T1 - T0
240 IF DT < 30 THEN PRINT "TEST: RENDER_BENCH_OK = PASS" ELSE PRINT "TEST: RENDER_BENCH_OK = FAIL"
250 PRINT "BENCH: 5 full renders in "; DT; "s"
260 PRINT ""
270 PRINT "INIT SMOKE COMPLETE (not the playable game)"
280 END

6000 REM -------- RENDER --------
6010 DC = 1 - CAMX
6020 DR = 2 - CAMY
6030 MAPDRAW DC, DR
6040 SCX = PX - CAMX
6050 SCY = PY - CAMY + 2
6060 TILE SCX, SCY, 200, LIME, BLACK
6070 RETURN

8000 REM -------- BUILD WORLD (minimal) --------
8010 MAPNEW 40, 26, "island", 46, WHITE, BLACK
8020 FOR X = 0 TO 39
8030 MAPSET X, 0, 35, CYAN, BLACK
8040 MAPSET X, 25, 35, CYAN, BLACK
8050 NEXT X
8110 MAPSET 8, 6, 201, GREEN, BLACK
8120 MAPSET 34, 11, 42, YELLOW, BLACK
8130 MAPSET 22, 12, 68, RED, BLACK
8140 RETURN

9000 REM -------- CUSTOM TILES (minimal) --------
9010 TILEDEF 200, 32, 32
9020 FOR I = 12 TO 19
9030 TILEPX 200, I, 12, 1
9040 NEXT I
9050 TILEDEF 201, 32, 32
9060 FOR Y = 8 TO 18
9070 FOR X = 12 TO 18
9080 IF ABS(X - 15) + ABS(Y - 13) < 6 THEN TILEPX 201, X, Y, 1
9090 NEXT X
9100 NEXT Y
9110 RETURN