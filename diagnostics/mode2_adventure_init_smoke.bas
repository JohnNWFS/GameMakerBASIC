5 REM ============================================================
10 REM Crystal Caves init smoke — tiles + map + one MAPDRAW
20 REM ============================================================
30 MODE 2, 32
40 CLSCHAR 32, WHITE, BLACK
50 GOSUB 9000
60 IF TILEBIT(200, 15, 12) = 1 THEN PRINT "TEST: HERO_TILE = PASS" ELSE PRINT "TEST: HERO_TILE = FAIL"
70 GOSUB 8000
80 VIEW 0, 2, 38, 18
90 PX = 4
100 PY = 4
110 CAMX = 0
120 CAMY = 0
130 GOSUB 6000
140 IF TILECHAR(9, 8) = 201 THEN PRINT "TEST: TREE_VISIBLE = PASS" ELSE PRINT "TEST: TREE_VISIBLE = FAIL"
150 IF TILECHAR(5, 6) = 46 THEN PRINT "TEST: FLOOR_VISIBLE = PASS" ELSE PRINT "TEST: FLOOR_VISIBLE = FAIL"
160 IF TILECHAR(4, 6) = 200 THEN PRINT "TEST: HERO_DRAWN = PASS" ELSE PRINT "TEST: HERO_DRAWN = FAIL"
170 T0 = TIMER
180 FOR I = 1 TO 30
190 GOSUB 6000
200 NEXT I
210 T1 = TIMER
220 DT = T1 - T0
230 IF DT > 0 AND DT < 60 THEN PRINT "TEST: RENDER_BENCH_OK = PASS" ELSE PRINT "TEST: RENDER_BENCH_OK = FAIL"
240 PRINT "BENCH: 30 full renders in "; DT; "s (~"; INT(30 / DT); " fps, TIMER integer)"
250 PRINT ""
260 PRINT "ADVENTURE INIT SMOKE COMPLETE"
270 END

6000 REM -------- RENDER (from adventure POC) --------
6010 DC = 1 - CAMX
6020 DR = 2 - CAMY
6030 MAPDRAW DC, DR
6040 SCX = PX - CAMX
6050 SCY = PY - CAMY + 2
6060 TILE SCX, SCY, 200, LIME, BLACK
6070 RETURN

