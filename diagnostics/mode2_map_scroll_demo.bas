5 REM ============================================================
10 REM MODE 2 map scroll — large map + VIEW + MAPDRAW camera offset
20 REM Move the "camera" by changing MAPDRAW col (negative = scroll right)
30 REM ============================================================
40 MODE 2, 32
50 CLSCHAR 32, WHITE, BLACK
60 PRINTAT 0, 0, "MAP SCROLL DEMO", YELLOW, BLACK
70 PRINTAT 0, 1, "HUD STAYS OUTSIDE VIEW", WHITE, BLACK
80 MAPNEW 56, 28, "world"
90 FOR X = 0 TO 55
100 MAPSET X, 0, 35
110 MAPSET X, 27, 35
120 NEXT X
130 FOR Y = 0 TO 27
140 MAPSET 0, Y, 35
150 MAPSET 55, Y, 35
160 NEXT Y
170 MAPSET 10, 5, 65, CYAN, BLACK
180 MAPSET 30, 5, 66, CYAN, BLACK
190 MAPSET 45, 5, 67, CYAN, BLACK
200 VIEW 1, 3, 38, 20
210 MAPDRAW 1, 3
220 IF TILECHAR(11, 8) = 65 THEN PRINT "TEST: MARKER_A_CAM0 = PASS" ELSE PRINT "TEST: MARKER_A_CAM0 = FAIL"
230 MAPDRAW -14, 3
240 IF TILECHAR(16, 8) = 66 THEN PRINT "TEST: MARKER_B_CAM15 = PASS" ELSE PRINT "TEST: MARKER_B_CAM15 = FAIL"
250 MAPDRAW -29, 3
260 IF TILECHAR(16, 8) = 67 THEN PRINT "TEST: MARKER_C_CAM30 = PASS" ELSE PRINT "TEST: MARKER_C_CAM30 = FAIL"
270 IF TILECHAR(0, 0) = 77 THEN PRINT "TEST: HUD_INTACT = PASS" ELSE PRINT "TEST: HUD_INTACT = FAIL"
280 VIEW OFF
290 PRINTAT 0, 23, "CAM: MAPDRAW 1-CAM, 3  (try CAM=0,15,30)", GREEN, BLACK
300 PRINT ""
310 PRINT "MAP SCROLL DEMO COMPLETE"
320 END