10 REM COLOR MOSAIC - NW-BASIC MODE 2 TILE DEMO
20 MODE 2, 32
30 CLSCHAR 32, WHITE, BLACK
40 PRINTAT 10, 0, "NW-BASIC MODE 2 TILE DEMO", YELLOW, BLACK
50 REM DRAW DOUBLE BORDER (char 35 = #, char 42 = *)
60 FOR I = 0 TO 39
70 CHARAT I, 2, 35, CYAN, BLACK
80 CHARAT I, 22, 35, CYAN, BLACK
90 NEXT I
100 FOR I = 2 TO 22
110 CHARAT 0, I, 35, CYAN, BLACK
120 CHARAT 39, I, 35, CYAN, BLACK
130 NEXT I
140 CHARAT 0, 2, 42, YELLOW, BLACK
150 CHARAT 39, 2, 42, YELLOW, BLACK
160 CHARAT 0, 22, 42, YELLOW, BLACK
170 CHARAT 39, 22, 42, YELLOW, BLACK
180 REM CHECKERBOARD FILL 1-38, 3-21
190 FOR Y = 3 TO 21
200 FOR X = 1 TO 38
210 LET C = (X + Y) MOD 2
220 IF C = 0 THEN CHARAT X, Y, 32, WHITE, NAVY
230 IF C = 1 THEN CHARAT X, Y, 32, WHITE, DKGRAY
240 NEXT X
250 NEXT Y
260 REM COLORED COLUMN HEADERS (chars 49-57 = 1-9)
270 FOR I = 0 TO 8
280 CHARAT 5 + I * 4, 4, 49 + I, LIME, BLACK
290 NEXT I
300 REM ROW MARKERS - alternating red/orange dots (char 111 = o)
310 FOR I = 0 TO 6
320 CHARAT 2, 5 + I * 2, 111, RED, BLACK
330 CHARAT 2, 6 + I * 2, 111, ORANGE, BLACK
340 NEXT I
350 REM CENTER TITLE BOX (clear it first)
360 FOR Y = 9 TO 14
370 FOR X = 8 TO 31
380 CHARAT X, Y, 32, WHITE, BLACK
390 NEXT X
400 NEXT Y
410 CHARAT 8, 9, 43, CYAN, BLACK
420 CHARAT 31, 9, 43, CYAN, BLACK
430 CHARAT 8, 14, 43, CYAN, BLACK
440 CHARAT 31, 14, 43, CYAN, BLACK
450 FOR I = 9 TO 31
460 CHARAT I, 9, 45, CYAN, BLACK
470 CHARAT I, 14, 45, CYAN, BLACK
480 NEXT I
490 FOR I = 9 TO 14
500 CHARAT 8, I, 124, CYAN, BLACK
510 CHARAT 31, I, 124, CYAN, BLACK
520 NEXT I
530 PRINTAT 10, 11, "NW-BASIC TILE MODE", YELLOW, BLACK
540 PRINTAT 12, 12, "johnnwfs.net", LIME, BLACK
550 END
