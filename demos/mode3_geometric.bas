10 REM GEOMETRIC ART - NW-BASIC MODE 3 PIXEL DEMO
20 MODE 3
30 CLS
40 REM FILL BLACK BACKGROUND
50 BOX 0, 0, 1280, 800, BLACK, 1, BLACK
60 REM CONCENTRIC CIRCLES - CENTER OF SCREEN
70 LET CX = 640
80 LET CY = 400
90 FOR R = 300 TO 20 STEP -40
100 LET C = R MOD 6
110 IF C = 0 THEN CIRCLE CX, CY, R, RED, 0
120 IF C = 2 THEN CIRCLE CX, CY, R, ORANGE, 0
130 IF C = 4 THEN CIRCLE CX, CY, R, YELLOW, 0
140 IF C = 1 THEN CIRCLE CX, CY, R, LIME, 0
150 IF C = 3 THEN CIRCLE CX, CY, R, CYAN, 0
160 IF C = 5 THEN CIRCLE CX, CY, R, MAGENTA, 0
170 NEXT R
180 REM STAR BURST - 18 LINES (20 deg apart, in radians = 0.3491 per step)
190 FOR I = 0 TO 17
200 LET RAD = I * 0.3491
210 LET XE = CX + 340 * COS(RAD)
220 LET YE = CY + 340 * SIN(RAD)
230 LINE CX, CY, XE, YE, WHITE, 1
240 NEXT I
250 REM FOUR CORNER BOXES WITH FILLED CIRCLES
260 BOX 10, 10, 170, 170, CYAN, 1, NAVY
270 BOX 1110, 10, 1270, 170, CYAN, 1, NAVY
280 BOX 10, 630, 170, 790, CYAN, 1, NAVY
290 BOX 1110, 630, 1270, 790, CYAN, 1, NAVY
300 CIRCLE 90, 90, 60, YELLOW, 1, ORANGE
310 CIRCLE 1190, 90, 60, YELLOW, 1, ORANGE
320 CIRCLE 90, 710, 60, YELLOW, 1, ORANGE
330 CIRCLE 1190, 710, 60, YELLOW, 1, ORANGE
340 REM OUTER BORDER FRAMES
350 BOX 0, 0, 1279, 799, WHITE, 0
360 BOX 5, 5, 1274, 794, GRAY, 0
370 REM PRINT LABEL IN OUTPUT AREA
380 PRINT "GEOMETRIC ART - NW-BASIC MODE 3 DEMO"
390 END
